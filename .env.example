# Copia este archivo como ".env" para desarrollo local (nunca subas el .env real a GitHub)

# --- Supabase (Project Settings → API en tu proyecto de Supabase) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Anthropic (Claude API para Chef IA) ---
ANTHROPIC_API_KEY=

# --- Supabase Admin (Project Settings → API → "service_role" — SECRETA, solo backend) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Paddle (Developer tools → Authentication en tu Dashboard de Paddle) ---
# Client-side token: público, se usa en el navegador
VITE_PADDLE_CLIENT_TOKEN=
VITE_PADDLE_ENV=sandbox
VITE_PADDLE_PRICE_MENSUAL=
VITE_PADDLE_PRICE_ANUAL=
VITE_PADDLE_PRICE_CHEF_MENSUAL=
VITE_PADDLE_PRICE_CHEF_ANUAL=

# API key: secreta, solo backend (webhook)
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_PRICE_CHEF_MENSUAL=
PADDLE_PRICE_CHEF_ANUAL=
